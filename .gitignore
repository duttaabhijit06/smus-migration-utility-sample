# =============================================================================
# .gitignore — SageMaker Unified Studio Migration repo
# =============================================================================
#
# Ignore runtime-generated artifacts, build caches, IDE settings, and
# locally-bootstrapped config files. Templates, examples, and source
# code stay tracked.

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
.Python
build/
dist/
develop-eggs/
downloads/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments — bootstrapped per machine; never commit.
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Test / lint caches
# -----------------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
nosetests.xml
.cache/

# -----------------------------------------------------------------------------
# IDE / tooling
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Kiro local agent state. The `.kiro/specs/` and `.kiro/steering/`
# subdirs are part of the repo's spec workflow (kept), but the
# top-level `.kiro/` cache and per-machine settings are not.
.kiro/cache/
.kiro/settings/
.kiro/.lock

# Claude / Cursor / Cody local files
.claude/
.cursor/
.codyignore

# -----------------------------------------------------------------------------
# Scratch space — local experiments, never tracked
# -----------------------------------------------------------------------------
.scratch/

# -----------------------------------------------------------------------------
# Migration-tool runtime state
# -----------------------------------------------------------------------------
# Runtime state file is generated by `migrate.sh run`; backups are
# created by `migrate.sh teardown` and `reset`. Never commit either.
state/migration.state.json
state/migration.state.json.bak.*

# Per-step outputs are regenerated on every `migrate.sh run`. The
# `outputs/` directories themselves are part of the layout, so we
# track .gitkeep files (if present) but ignore everything else inside.
steps/**/outputs/*
!steps/**/outputs/.gitkeep

# Top-level run logs from migrate.sh tee'd output.
logs/
*.log

# -----------------------------------------------------------------------------
# Seed (sandbox bootstrap) state
# -----------------------------------------------------------------------------
# `seed.config.json` is bootstrapped on first run from
# `seed.config.json.example` (which IS tracked). The instantiated
# version contains account-specific values; do not commit.
seed/seed.config.json
seed/seed.config.json.bak.*

# Same pattern for the seed state file.
seed/seed.state.json
seed/seed.state.json.bak.*
seed/seed.state.json.bak.before-recovery

# Seed run logs.
seed/logs/

# -----------------------------------------------------------------------------
# CloudFormation
# -----------------------------------------------------------------------------
# `params.json.template` is the tracked source-of-truth; the rendered
# `params.json` is account/region-specific.
cfn/params.json

# -----------------------------------------------------------------------------
# Migration-tool config
# -----------------------------------------------------------------------------
# `config/migration.config.json` is created by the migration tool's
# first-run prompts and contains source_account_id + other locals.
config/migration.config.json
config/migration.config.json.bak.*

# -----------------------------------------------------------------------------
# Cached AWS doc fetches and other transient docs
# -----------------------------------------------------------------------------
docs/cache/

# -----------------------------------------------------------------------------
# AWS / credentials guardrail
# -----------------------------------------------------------------------------
# Defensive: never let .env / credentials / keys land in the repo.
.env
.env.*
!.env.example
*.pem
*.key
credentials
credentials.*
